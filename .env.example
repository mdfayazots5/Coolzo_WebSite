# Coolzo Frontend Environment Variables
# Copy this file to .env.development or .env.production and fill in the values.
# Never commit .env.development or .env.production to source control.

# Backend API base URL (no trailing slash)
# Development: https://localhost:44394
# Production:  https://api.coolzo.com
VITE_API_BASE_URL=

# Public CDN origin the static CMS snapshot is served from (no trailing slash).
# Set this to the Cloudflare R2 public/CDN base URL in production (e.g. https://cdn.coolzo.com).
# Leave empty in dev (FileSystem storage) — it falls back to VITE_API_BASE_URL.
VITE_SNAPSHOT_BASE_URL=
